@page "/hall/{ScreeningId:int}"
@rendermode InteractiveServer
@inject CinemaCatalogService Catalog
@inject BookingService Booking
@inject NavigationManager Navigation

<PageTitle>Zāles plāns — KINO NOX</PageTitle>
@if (Screening is null || Movie is null) { <p class="empty-state">Seanss nav atrasts.</p> }
else
{
<section class="hall-page"><a class="back-link" href="movie/@Movie.Id">← @Movie.Title</a><div class="section-head"><div><p class="eyebrow">@Screening.StartsAt.ToString("dd. MMMM · HH:mm")</p><h1>@Screening.Hall</h1></div><p class="muted">Izvēlieties vietas. Tās tiks īslaicīgi aizsargātas pēc pasūtījuma apstiprināšanas.</p></div><div class="screen"><span>EKRĀNS</span></div><div class="seat-map">@for (var row = 1; row <= Hall.Rows; row++) { var rowLetter = ((char)('A' + row - 1)).ToString(); <div class="seat-row"><span>@rowLetter</span>@for (var seat = 1; seat <= Hall.SeatsPerRow; seat++) { var seatId = $"{rowLetter}{seat}"; var unavailable = !Booking.IsAvailable(ScreeningId, seatId); <button class="seat @(unavailable ? "occupied" : "") @(SelectedSeats.Contains(seatId) ? "selected" : "")" disabled="@unavailable" @onclick="() => ToggleSeat(seatId)">@seat</button> }</div> }</div><div class="seat-legend"><span><i class="seat"></i> Brīva</span><span><i class="seat selected"></i> Izvēlēta</span><span><i class="seat occupied"></i> Aizņemta</span></div><div class="selection-bar"><span>@(SelectedSeats.Count == 0 ? "Izvēlieties vietas zāles plānā" : $"Izvēlētas vietas: {string.Join(", ", SelectedSeats.Order())}")</span><button class="button button-primary" disabled="@(SelectedSeats.Count == 0)" @onclick="Continue">Turpināt <span>→</span></button></div></section>
}
@code { [Parameter] public int ScreeningId { get; set; } private HashSet<string> SelectedSeats { get; } = []; private Screening? Screening => Catalog.Screenings.SingleOrDefault(item => item.Id == ScreeningId); private Movie? Movie => Screening is null ? null : Catalog.FindMovie(Screening.MovieId); private Hall Hall => Catalog.Halls.Single(hall => hall.Name == Screening!.Hall); private void ToggleSeat(string seat) { if (!SelectedSeats.Add(seat)) SelectedSeats.Remove(seat); } private void Continue() => Navigation.NavigateTo($"checkout/{ScreeningId}?seats={Uri.EscapeDataString(string.Join(',', SelectedSeats))}"); }
