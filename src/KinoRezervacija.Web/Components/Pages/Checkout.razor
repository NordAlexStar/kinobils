@page "/checkout/{ScreeningId:int}"
@rendermode InteractiveServer
@inject CinemaCatalogService Catalog
@inject BookingService Booking
@inject CustomerSession Session
@inject NavigationManager Navigation

<PageTitle>Pasūtījums — KINO NOX</PageTitle>
@if (Screening is null || Movie is null) { <p class="empty-state">Pasūtījums nav atrasts.</p> } else { <section class="checkout-page"><a class="back-link" href="hall/@ScreeningId">← Mainīt vietas</a><div class="checkout-grid"><div class="checkout-main"><p class="eyebrow">PASŪTĪJUMA APSTIPRINĀŠANA</p><h1>@Movie.Title</h1><p class="muted">@Screening.StartsAt.ToString("dddd, dd. MMMM · HH:mm") · @Screening.Hall</p><div class="ticket-line"><span>Vietas</span><b>@string.Join(", ", SelectedSeats)</b></div><div class="ticket-line"><span>Biļetes</span><b>@SelectedSeats.Count × @Screening.Price.ToString("0.00") €</b></div><div class="ticket-line total"><span>Kopā</span><b>@(Screening.Price * SelectedSeats.Count).ToString("0.00") €</b></div><div class="checkout-email">@if (Session.IsAuthenticated) { <p>Biļeti nosūtīsim uz <b>@Session.Email</b>.</p> } else { <p>Turpināt kā viesim</p><EditForm Model="Guest" OnValidSubmit="Pay"><DataAnnotationsValidator /><label>E-pasts biļetes saņemšanai<InputText @bind-Value="Guest.Email" type="email" /></label><ValidationMessage For="() => Guest.Email" /><button class="button button-primary" type="submit">Apmaksāt un saņemt biļeti <span>→</span></button></EditForm> } @if (Session.IsAuthenticated) { <button class="button button-primary" @onclick="Pay">Apmaksāt un saņemt biļeti <span>→</span></button> } @if (Message is not null) { <p class="form-message">@Message</p> }</div></div><aside class="checkout-poster"><img src="@Movie.PosterPath" alt="@Movie.Title" /></aside></div></section> }
@code { [Parameter] public int ScreeningId { get; set; } [SupplyParameterFromQuery] public string? Seats { get; set; } private Screening? Screening => Catalog.Screenings.SingleOrDefault(item => item.Id == ScreeningId); private Movie? Movie => Screening is null ? null : Catalog.FindMovie(Screening.MovieId); private IReadOnlyList<string> SelectedSeats => (Seats ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries); private GuestInput Guest { get; set; } = new(); private string? Message { get; set; } private void Pay() { var email = Session.Email ?? Guest.Email; var order = Booking.Reserve(ScreeningId, SelectedSeats, email, out var message); if (order is null) { Message = message; return; } Navigation.NavigateTo($"ticket/{order.Id}"); } private sealed class GuestInput { [Required, EmailAddress] public string Email { get; set; } = ""; } }
