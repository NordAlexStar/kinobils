@page "/account"
@rendermode InteractiveServer
@inject BookingService Booking
@inject CustomerSession Session

<PageTitle>Konts — KINO NOX</PageTitle>
<section class="account-page"><div class="account-copy"><p class="eyebrow">KINO NOX KONTS</p><h1>Vieta, kur paliek<br /><i>tavas biļetes.</i></h1><p>Reģistrēts konts ļauj atrast biļetes arī pēc seansa. Biļeti vari iegādāties arī kā viesis.</p></div><div class="account-form"><div class="account-tabs"><button class="@(RegisterMode ? "" : "active")" @onclick="() => RegisterMode = false">Ienākt</button><button class="@(RegisterMode ? "active" : "")" @onclick="() => RegisterMode = true">Reģistrēties</button></div>@if (Session.IsAuthenticated) { <h2>Tu esi ienācis</h2><p class="muted">@Session.Email</p><button class="button button-primary" @onclick="SignOut">Iziet</button> } else { <EditForm Model="Input" OnValidSubmit="Submit"><DataAnnotationsValidator /><ValidationSummary /><label>E-pasts<InputText @bind-Value="Input.Email" type="email" /></label><label>Parole<InputText @bind-Value="Input.Password" type="password" /></label><button class="button button-primary" type="submit">@(RegisterMode ? "Izveidot kontu" : "Ienākt") <span>→</span></button></EditForm> } @if (Message is not null) { <p class="form-message">@Message</p> }</div></section>
@code { private bool RegisterMode { get; set; } private string? Message { get; set; } private Credentials Input { get; set; } = new(); private void Submit() { if (RegisterMode) { if (Booking.Register(Input.Email, Input.Password, out var message)) Session.SignIn(Input.Email); Message = message; } else { if (Booking.SignIn(Input.Email, Input.Password)) { Session.SignIn(Input.Email); Message = "Laipni lūdzam atpakaļ."; } else Message = "Nepareizs e-pasts vai parole."; } } private void SignOut() { Session.SignOut(); Message = null; } private sealed class Credentials { [Required, EmailAddress] public string Email { get; set; } = ""; [Required, MinLength(8)] public string Password { get; set; } = ""; } }
